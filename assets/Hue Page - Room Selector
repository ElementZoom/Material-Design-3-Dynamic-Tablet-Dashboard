                        - automation.room_presence_hallway
                      room_boolean: input_boolean.hallway_dynamic_scene
                      room_scene_tracker: input_text.hallway_dynamic_scene_active
                  color: >-
                    {% if states('input_text.hallway_dynamic_scene_active') !=
                    '' %}
