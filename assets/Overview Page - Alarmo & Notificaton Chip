                          type: template
                          entity: alarm_control_panel.alarmo
                          content: Triggered
                          tap_action:
                            action: navigate
                            navigation_path: /tablet-dashboard/alarmo
                          icon: mdi:bell-ring
                          icon_color: "#d14f3a"
                      - type: conditional
                        conditions:
                          - entity: alarm_control_panel.alarmo
                            state: armed_away
