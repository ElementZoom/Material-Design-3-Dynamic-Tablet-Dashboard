type: custom:mod-card
uix:
  style: |
    ha-card {

      animation: fadeInRight 0.5s ease-out 0.5s;
    }
    @keyframes fadeInRight {
      from {
        opacity: 1;
        transform: translateX(8px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
card:
