                          type: template
                          entity: alarm_control_panel.alarmo
                          content: Pending
                          tap_action:
                            action: navigate
                            navigation_path: /tablet-dashboard/alarmo
                          icon: mdi:shield-outline
                          icon_color: "#efa340"
