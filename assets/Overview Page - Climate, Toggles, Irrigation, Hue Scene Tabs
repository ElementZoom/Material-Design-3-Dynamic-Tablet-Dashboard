                          {% endif %}
                      - type: template
                        entity: automation.room_presence_master_bedroom
                        icon: m3of:bed
                        icon_color: |-
                          {% if is_state(entity, 'on') %} 
                          {% else %}
                           #a8a8a8
                          {% endif %}
                        tap_action:
                          action: toggle
                        content: |-
                          {% if is_state(entity, 'on') %} 
                            Master
                          {% else %}
                          {% endif %}
                      - type: template
