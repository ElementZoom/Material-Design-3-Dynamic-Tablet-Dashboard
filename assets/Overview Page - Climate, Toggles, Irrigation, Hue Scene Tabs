                            Baby
                          {% else %}
                          {% endif %}      
                      - type: template
                        entity: automation.room_presence_single_guest_room
                        icon: m3of:person-3
                        icon_color: |-
                          {% if is_state(entity, 'on') %} 
                          {% else %}
